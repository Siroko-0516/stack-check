{
  "expo": {
    "name": "영양제 무더기",
    "slug": "stack-check",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.stackcheck.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "name": "영양제 무더기",
      "shortName": "영양제무더기",
      "themeColor": "#0f766e",
      "backgroundColor": "#f0fdfa",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "영양제 라벨을 분석하려면 사진 접근이 필요합니다.",
          "cameraPermission": "영양제 무더기를 촬영하려면 카메라 접근이 필요합니다."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fad331e5-8216-4964-9ca8-4ab5b74e6beb"
      }
    }
  }
}
